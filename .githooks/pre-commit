#!/bin/sh

# 1. Remove unused images from _images/ directories
node scripts/cleanup-unused-images.mjs

# 2. Sync EN structure (imports, frontmatter, images, trailing spaces)
node scripts/sync-en-structure.mjs || exit 1

# 3. Auto-translate changed i18n values (JA→EN) via Claude CLI
node scripts/sync-i18n-values.mjs

# 4. Translation checks
node scripts/check-translations.mjs || exit 1
node scripts/check-garage-translations.mjs || exit 1

# 4. Auto-resize images in _images/ directories before commit
# Resizes to max 1600px width using sharp

IMAGES=$(git diff --cached --name-only --diff-filter=ACM | grep '_images/.*\.\(jpg\|jpeg\|png\|webp\)$' || true)

if [ -z "$IMAGES" ]; then
  exit 0
fi

echo "Pre-commit: resizing images in _images/..."
node scripts/resize-staged-images.mjs $IMAGES
