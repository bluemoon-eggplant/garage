---
import DataTable from '@/components/react/DataTable';
import type { Column } from '@/components/react/DataTable';

export interface CarRecord {
  date: string;
  mileage: number;
  price: number;
  fuelCost?: number;
  maintenance?: number;
  notes?: string;
}

interface Props {
  data: CarRecord[];
  caption?: string;
  frozenColumns?: number;
}

const { data, caption, frozenColumns = 1 } = Astro.props;

const columns: Column[] = [
  {
    key: 'date',
    label: '日付',
    width: '120px',
  },
  {
    key: 'mileage',
    label: '走行距離 (km)',
    dataBar: true,
    barColor: 'rgb(34, 197, 94)', // green-500
    format: (v: number) => v.toLocaleString() + ' km',
    width: '150px',
  },
  {
    key: 'price',
    label: '価格 (税込)',
    dataBar: true,
    barColor: 'rgb(59, 130, 246)', // blue-500
    format: (v: number) => '¥' + v.toLocaleString(),
    width: '150px',
  },
  {
    key: 'fuelCost',
    label: '燃料費',
    dataBar: true,
    barColor: 'rgb(249, 115, 22)', // orange-500
    format: (v: number) => v ? '¥' + v.toLocaleString() : '-',
    width: '120px',
  },
  {
    key: 'maintenance',
    label: '整備費',
    dataBar: true,
    barColor: 'rgb(168, 85, 247)', // purple-500
    format: (v: number) => v ? '¥' + v.toLocaleString() : '-',
    width: '120px',
  },
  {
    key: 'notes',
    label: '備考',
    width: '200px',
  },
];
---

<DataTable
  client:load
  columns={columns}
  data={data}
  frozenColumns={frozenColumns}
  caption={caption}
/>
