---
import { Icon } from 'astro-icon/components';

import Button from '@/components/Button.astro';
import { ROUTES } from '@/constants/routes';
import { useTranslations } from '@/i18n';
import { localizedPath } from '@/utils/i18n';

export interface Props {
  category?: string;
}

const { category } = Astro.props;
const locale = Astro.currentLocale;
const t = useTranslations(locale);

const recordHref = localizedPath(locale, category
  ? `${ROUTES.RECORD_CATEGORIES}${category}`
  : ROUTES.RECORD);

const blogHref = localizedPath(locale, category
  ? `${ROUTES.EXPLORE_CATEGORIES}${category}`
  : ROUTES.EXPLORE);
---

<div class="not-prose flex justify-center gap-3 my-4">
  <Button href={recordHref} size="md" variant="outline" colors="primary">
    <Icon name="mdi:table" slot="before-icon" />
    {t('garage.jumpToRecord')}
  </Button>
  <Button href={blogHref} size="md" variant="outline" colors="primary">
    <Icon name="mdi:post-outline" slot="before-icon" />
    {t('garage.jumpToBlog')}
  </Button>
</div>
