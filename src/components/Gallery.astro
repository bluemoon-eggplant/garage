---
import { getImage } from 'astro:assets';

import ReactGallery from '@/components/react/Gallery';
import { IMAGE_SIZES } from '@/constants/image';
import { randomizeArray } from '@/utils/objects';
import { cn } from '@/utils/styles';
import { getFilenameWithoutExtension } from '@/utils/paths';
import { useTranslations } from '@/i18n';

import type { ImageProps } from '@/types/common';
import type { ImageMetadata } from 'astro';

export interface Props extends astroHTML.JSX.HTMLAttributes {}

/** Only return images that are used in blog posts */
const getBlogImagesMetadata = (blogImageFilenames: Set<string>): ImageMetadata[] => {
  const garageImageModules = import.meta.glob<{ default: ImageMetadata }>(
    '/src/content/garage/**/_images/*.{jpg,png,webp}',
    { eager: true }
  );

  return Object.entries(garageImageModules)
    .filter(([path]) => {
      return blogImageFilenames.has(getFilenameWithoutExtension(path));
    })
    .map(([, mod]) => mod.default);
};

/**
 * Build imageMap: garage image filename → blog post URL.
 * Scan blog MDX files for `import ... from '..._images/...'` to find which
 * blog post uses which garage image.
 */
const buildImageMap = (): Record<string, string> => {
  const map: Record<string, string> = {};

  // Read all blog MDX files as raw text
  const postMdxModules = import.meta.glob<string>(
    '/src/content/post/**/index.mdx',
    { eager: true, query: '?raw', import: 'default' }
  );

  const importRegex = /from\s+['"].*_images\/([^'"]+)['"]/g;

  for (const [mdxPath, raw] of Object.entries(postMdxModules)) {
    // Extract blog slug from path: /src/content/post/2025/05-06-fd3s-maintenance/index.mdx
    // Slug is the directory name right before index.mdx (no year prefix)
    const parts = mdxPath.split('/');
    const slug = parts[parts.length - 2];
    const blogUrl = `/blog/${slug}`;

    let match;
    while ((match = importRegex.exec(raw)) !== null) {
      // match[1] = "PXL_20250506_073305551.jpg"
      const imageFilename = getFilenameWithoutExtension(match[1]);
      map[imageFilename] = blogUrl;
    }
  }

  return map;
};

const imageMap = buildImageMap();
const imagesMetadata = getBlogImagesMetadata(new Set(Object.keys(imageMap)));

function getBlogLink(imageSrc: string): string {
  return imageMap[getFilenameWithoutExtension(imageSrc)] || '#';
}

const galleryCaption = useTranslations(Astro.currentLocale)('gallery.viewArticle');

const imageMetadataToReactImageProps = async (
  imagesMetadata: ImageMetadata
): Promise<ImageProps> => {
  const astroImageProps = {
    src: imagesMetadata,
    format: 'webp',
  };

  // Preserve original aspect ratio — only constrain width
  const thumbWidth = IMAGE_SIZES.FIXED.MDX_XS.width;
  const aspectRatio = imagesMetadata.height / imagesMetadata.width;
  const thumbHeight = Math.round(thumbWidth * aspectRatio);

  const thumbnailAstroImageProps = {
    ...astroImageProps,
    width: thumbWidth,
    height: thumbHeight,
    alt: 'Thumbnail',
  };

  const lightboxWidth = IMAGE_SIZES.FIXED.MDX_XL.width;
  const lightboxHeight = Math.round(lightboxWidth * aspectRatio);

  const lightboxAstroImageProps = {
    ...astroImageProps,
    width: lightboxWidth,
    height: lightboxHeight,
    alt: 'Lightbox',
  };

  const optimizedThumbnailAstroImageProps = await getImage(thumbnailAstroImageProps);
  const { src, attributes } = optimizedThumbnailAstroImageProps;

  const optimizedLightboxAstroImageProps = await getImage(lightboxAstroImageProps);
  const { src: originalSrc } = optimizedLightboxAstroImageProps;

  const link = getBlogLink(String(imagesMetadata.src));
  const reactImageProps = {
    src,
    originalSrc,
    // width and height only for thumbnails
    width: parseInt(String(attributes.width)),
    height: parseInt(String(attributes.height)),
    link,
    caption: galleryCaption,
  };

  return reactImageProps;
};

const reactImages = await Promise.all(
  imagesMetadata.map((metadata) => imageMetadataToReactImageProps(metadata))
);

const randomizedReactImages = randomizeArray(reactImages);

// console.log('reactImages', reactImages);

const { class: className } = Astro.props;
---

<div class={cn('', className)}>
  <ReactGallery client:only="react" images={randomizedReactImages} />
</div>
