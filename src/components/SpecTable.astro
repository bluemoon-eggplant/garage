---
interface Props {
  items: [string, string][];
}

const { items } = Astro.props;
---

<table class="w-full text-sm my-4">
  <tbody>
    {items.map(([label, value], i) => (
      <tr class={i % 2 === 0 ? 'bg-base-200/50' : ''}>
        <td class="px-3 py-2 text-content/60 whitespace-nowrap w-1/3">{label}</td>
        <td class="px-3 py-2 font-medium text-content">{value}</td>
      </tr>
    ))}
  </tbody>
</table>
