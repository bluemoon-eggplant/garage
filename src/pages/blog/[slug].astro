---
import { Icon } from 'astro-icon/components';
import { render } from 'astro:content';

import { getAllPostsWithReadingTime } from '@/modules/post/common';
import { getRandomPosts } from '@/modules/post/random';
import { loadAllMaintenanceRecords } from '@/libs/record-data';
import { default as PostLayout } from '@/layouts/Post.astro';

import PostListMore from '@/components/PostListMore.astro';
import PostMeta from '@/components/PostMeta.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import { getHeadingsForTableOfContents } from '@/modules/post/table-of-contents';
import Share from '@/components/Share.astro';
import { ROUTES } from '@/constants/routes';
import { useTranslations } from '@/i18n';
import { setTransitionSlug, TRANSITION_ELEMENT_IDS } from '@/constants/transitions';
import { CONFIG_CLIENT } from '@/config/client';
import { getOpenGraphImagePath } from '@/libs/api/open-graph/image-path';

import type { Metadata } from '@/types/common';
import type { Post } from '@/types/post';
import type { MaintenanceRecord } from '@/types/record';

const { SITE_URL } = CONFIG_CLIENT;
const t = useTranslations(Astro.currentLocale);

export async function getStaticPaths() {
  const posts: Post[] = await getAllPostsWithReadingTime();
  const records = loadAllMaintenanceRecords();

  const paths = posts.map((post, index) => {
    const { slug } = post;
    const { category, publishDate } = post.data;
    const randomPosts = getRandomPosts({ posts, excludeSlug: slug, category });

    // same category prev/next (posts are sorted by date desc)
    const sameCategoryPosts = posts.filter((p) => p.data.category === category);
    const categoryIndex = sameCategoryPosts.findIndex((p) => p.slug === slug);
    const prevPost = sameCategoryPosts[categoryIndex - 1] ?? null;
    const nextPost = sameCategoryPosts[categoryIndex + 1] ?? null;

    // Match record: same category + same date
    const postDateStr = `${publishDate.getFullYear()}/${String(publishDate.getMonth() + 1).padStart(2, '0')}/${String(publishDate.getDate()).padStart(2, '0')}`;
    const matchedRecord = records.find(
      (r) => r.category === category && r.date === postDateStr
    );

    return {
      params: { slug },
      props: { ...post, randomPosts, prevPost, nextPost, matchedRecord: matchedRecord ?? null },
    };
  });

  return paths;
}

const { data, readingTime, randomPosts, prevPost, nextPost, matchedRecord } = Astro.props as Post & {
  randomPosts: Post[];
  prevPost: Post | null;
  nextPost: Post | null;
  matchedRecord: MaintenanceRecord | null;
};
const {
  draft,
  title,
  publishDate,
  updatedDate,
  description,
  category,
} = data;

const { slug } = Astro.params;
const { pathname } = Astro.url;

const { Content, headings: rawHeadings } = await render(Astro.props);
const headings = getHeadingsForTableOfContents(rawHeadings);

const postMetaProps = {
  category,
  publishDate,
  updatedDate,
};

const shareProps = {
  title,
  description,
  url: `${SITE_URL}${ROUTES.BLOG}${slug}`,
};

const getTransitionNameFromElementId = setTransitionSlug({ pageSlug: slug });

// handle all metadata here
const image = getOpenGraphImagePath(pathname);

const metadata: Metadata = { title, description, image };
---

<PostLayout {metadata}>
<Fragment slot="hero-text">
    <h1
      class="b-h1"
      transition:name={getTransitionNameFromElementId({
        elementId: TRANSITION_ELEMENT_IDS.POST_CARD.TITLE,
      })}
    >
      {title}
      {draft && <sup class="text-red-500 ml-1">{t('blog.draft')}</sup>}
    </h1>

    {
      description && (
        <p
          class="font-normal text-content text-xl md:text-2xl mb-6 md:mb-8"
          transition:name={getTransitionNameFromElementId({
            elementId: TRANSITION_ELEMENT_IDS.POST_CARD.DESCRIPTION,
          })}
        >
          {description}
        </p>
      )
    }

    <PostMeta
      {...postMetaProps}
      transition:name={getTransitionNameFromElementId({
        elementId: TRANSITION_ELEMENT_IDS.POST_CARD.META,
      })}
    />
  </Fragment>

  <Fragment slot="content">
    {matchedRecord && (
      <a
        href={`${ROUTES.RECORD}detail/${matchedRecord.id}`}
        class="flex items-center gap-2 text-sm text-blue-600 dark:text-blue-400 hover:underline mb-4"
      >
        <Icon name="mdi:notebook-outline" class="w-5 h-5" />
        {t('blog.viewRecord')}
        <Icon name="mdi:arrow-right" class="w-4 h-4" />
      </a>
    )}

    {matchedRecord && matchedRecord.tasks.length > 0 && (
      <div class="rounded-lg border border-blue-200 dark:border-blue-800 bg-blue-50/50 dark:bg-blue-900/20 px-6 py-4 mb-8">
        <div class="flex items-center gap-2 mb-3">
          <Icon name="mdi:wrench" class="w-5 h-5 text-blue-600 dark:text-blue-400" />
          <h2 class="text-base font-bold text-gray-900 dark:text-gray-100">{t('blog.diyTasks')}</h2>
        </div>
        <ul class="list-disc list-inside text-sm text-gray-700 dark:text-gray-300 space-y-1">
          {matchedRecord.tasks.map((task) => (
            <li>{task}</li>
          ))}
        </ul>
      </div>
    )}

    {headings.length > 0 && (
      <TableOfContents headings={headings} class="mb-8" />
    )}

    <Content />
  </Fragment>

  <Fragment slot="after-content">
    <div class="flex justify-end b-h2-mb">
      <Share {...shareProps} />
    </div>

    <nav class="flex items-center justify-between gap-4 b-h2-mb">
      {prevPost ? (
        <a href={`${ROUTES.BLOG}${prevPost.slug}`} class="flex items-center gap-1 text-links hover:text-links-hover">
          <Icon name="mdi:chevron-left" class="w-5 h-5" />
          <span class="line-clamp-1">{prevPost.data.title}</span>
        </a>
      ) : <span />}
      {nextPost ? (
        <a href={`${ROUTES.BLOG}${nextPost.slug}`} class="flex items-center gap-1 text-links hover:text-links-hover text-right">
          <span class="line-clamp-1">{nextPost.data.title}</span>
          <Icon name="mdi:chevron-right" class="w-5 h-5" />
        </a>
      ) : <span />}
    </nav>

    <div class="flex justify-center">
      <a href={`${ROUTES.EXPLORE_CATEGORIES}${category}`} class="flex items-center gap-1 text-links hover:text-links-hover">
        <Icon name="mdi:arrow-left" class="w-4 h-4" />
        <span>{t('blog.backToList')}</span>
      </a>
    </div>
  </Fragment>

  <Fragment slot="more-posts">
    <PostListMore morePosts={randomPosts} />
  </Fragment>
</PostLayout>
