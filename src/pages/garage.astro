---
import { getAllGarageItems } from '@/modules/garage';
import List from '@/layouts/List.astro';
import GarageList from '@/components/GarageList.astro';
import { getPageMetadata } from '@/utils/metadata';

const items = await getAllGarageItems();
const metadata = getPageMetadata('lists/garage');

// ページネーションプロパティを空オブジェクトで渡す
const layoutProps = {
  metadata,
  paginationProps: {
    url: { current: '/garage', prev: undefined, next: undefined },
    currentPage: 1,
    lastPage: 1,
    start: 1,
    end: items.length,
    total: items.length,
  },
};
---

<List {...layoutProps}>
  <GarageList {items} />
</List>
